{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.codex/hooks/commit_pr_guard.py\"",
            "timeout": 10,
            "statusMessage": "checking for uncommitted work before finishing"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.codex/hooks/commit_pr_guard.py\"",
            "timeout": 10,
            "statusMessage": "checking commit/PR follow-up state"
          }
        ]
      }
    ]
  }
}
